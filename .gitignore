# ==========================================
# Unity 核心自动生成缓存（必须忽略，体积巨大）
# ==========================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emory[Ss]napshots/
/[Pp]rofiler[Ss]napshots/
/[Aa]ssembly[Oo]utput/

# ==========================================
# Unity 包管理（忽略缓存目录，保留 manifest.json 等配置）
# ==========================================
/Packages/[Pp]ackageCache/
# 下面两行若不需要提交，可取消注释（通常 manifest.json 需要提交）
# /Packages/manifest.json
# /Packages/packages-lock.json

# ==========================================
# VR 项目特定（忽略平台构建产物和临时录屏）
# ==========================================
# VR 平台安装包
*.apk
*.aab
*.obb
*.ipa
*.exe
*.msi

# 录屏/测试视频（如果不需要纳入版本控制）
*.mp4
*.mov
*.avi
*.webm

# VR 插件可能产生的额外缓存
*/[Ss]treamingAssets/*.manifest
*/[Ss]treamingAssets/*.assetbundle

# ==========================================
# IDE / 编辑器个人配置（不要同步给团队）
# ==========================================
# Visual Studio / Rider
/.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# VS Code
/.vscode/

# ==========================================
# 系统文件（各平台自动生成，无需提交）
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==========================================
# 你之前明确要忽略的具体文件
# ==========================================
demo.apk
Assets/Project/Art/Environment/source/model.obj
Assets/Models/stadium.fbx

# ==========================================
# 其他临时文件 / 备份文件
# ==========================================
*.log
*.bak
*.swp
*~
.localhistory/
*.tmp
*.cache
*.backup
*.pid
*.pidb.meta